// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  username    String   @unique
  name        String?
  password    String
  permissionId  Int?
  permission    Permission?  @relation(fields: [permissionId], references: [id])
  profile     Profile? @relation(fields: [profileId], references: [id])
  profileId   Int?     @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions   Transactions[]
  cashRegisterWithdraw  CashRegisterWithdraw[]
  cashRegisterTransaction  CashRegisterRecord[]
  entityAccount             EntityAccount[]
  cashRegisterAssignment    CashRegisterAssignment[]
  userAssociate              UserAssociate[]
  employeeProfile            EmployeeProfile?
  leaveRequests              LeaveRequest[]
  leaveApprovals             LeaveApproval[]
  salaries                   Salary[]
  expenses                   Expense[]
  managerOf                  UserManager[] @relation("Manager")
  reportsTo                  UserManager[] @relation("Employee")
  
  clockIns     ClockInOut[]  @relation("ClockInOutUser")
  approvals    ClockInOut[]  @relation("ClockInOutApprovedBy")
}

model Profile {
  id   Int     @id @default(autoincrement())
  bio  String?
  user User?
}



model Permission {
  id          Int       @id @default(autoincrement())
  name        String    @unique 
  permissions Json  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  
  users       User[]
  
  @@index([name])
}


model UserAssociate {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  associateName  String   // "store", "shop", "factory", "cashRegister", "account"
  associateId    Int      // ID of the specific entity
  

  @@unique([userId, associateName, associateId])
  @@index([userId])
  @@index([associateName, associateId])
}

model Accounts {
  id          Int       @id @default(autoincrement())
  name        String
  account_number   String    @unique
  balance     Float     @default(0)
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  transactions Transactions[]
  entityAssignments EntityAccount[]
  purchase     Purchase[]
  expenses     Expense[]

  @@index([createdAt])
}

model BankAccount {
  id                   Int       @id @default(autoincrement())
  name                String
  account_number      String    @unique
  starting_balance    Float     @default(0)
  current_balance     Float     @default(0)
  withdraw_charge     Float?
  transactions        Transactions[]
  sales               Sale[]
}

model EmployeeProfile {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designation  String?
  baseSalary   Float    @default(0)
  salaryType   String   @default("monthly") // monthly, hourly
  joiningDate  DateTime?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserManager {
  id         Int      @id @default(autoincrement())
  userId     Int
  managerId  Int
  user       User     @relation("Employee", fields: [userId], references: [id], onDelete: Cascade)
  manager    User     @relation("Manager", fields: [managerId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([userId, managerId])
  @@index([userId])
  @@index([managerId])
}

model ClockInOut {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("ClockInOutUser", fields: [userId], references: [id], onDelete: Cascade)
  clockIn      DateTime
  clockOut     DateTime?
  status       String   @default("open") // open, closed
  approvedById Int?
  approvedBy   User?    @relation("ClockInOutApprovedBy", fields: [approvedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([clockIn])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  isPaid      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model LeaveCategory {
  id          Int      @id @default(autoincrement())
  name        String
  isPaid      Boolean  @default(true)
  maxDays     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  Int
  category    LeaveCategory @relation(fields: [categoryId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  approvals   LeaveApproval[]

  @@index([userId])
  @@index([categoryId])
  @@index([startDate])
}

model LeaveApproval {
  id            Int      @id @default(autoincrement())
  leaveRequestId Int
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approverId     Int
  approver       User     @relation(fields: [approverId], references: [id])
  status         String   // approved, rejected
  note           String?
  decidedAt      DateTime @default(now())

  @@index([leaveRequestId])
  @@index([approverId])
}

model Salary {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  baseSalary   Float
  allowances   Float    @default(0)
  deductions   Float    @default(0)
  gross        Float
  net          Float
  status       String   @default("generated") // generated, approved, paid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expenses     Expense[]

  @@unique([userId, month, year])
  @@index([month, year])
}

model ExpenseCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expenses  Expense[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  accountId   Int
  account     Accounts @relation(fields: [accountId], references: [id])
  amount      Float
  date        DateTime
  description String?
  createdById Int?
  createdBy   User?   @relation(fields: [createdById], references: [id])
  salaryId    Int?
  salary      Salary? @relation(fields: [salaryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([date])
}


model CashRegisterAssignment {
  id                Int            @id @default(autoincrement())
  entityType        String         // "store", "shop", "factory"
  entityId          Int            // ID of the entity (store, shop, or factory)
  cashRegisterId    Int
  cashRegister      CashRegister   @relation(fields: [cashRegisterId], references: [id])
  assignedAt        DateTime       @default(now())
  assignedById      Int?
  assignedBy        User?          @relation(fields: [assignedById], references: [id])
  isActive          Boolean        @default(true)
  notes             String?
  
  @@unique([entityType, entityId, cashRegisterId])
  @@index([entityType, entityId])
  @@index([cashRegisterId])
  @@index([assignedAt])
  @@index([isActive])
}

model CashRegister {
  id          Int       @id @default(autoincrement())
  name        String
  status      String
  cash_in_hand Float              @default(0)
  last_opened DateTime?
  last_closed DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  transactions  Transactions[]
  cashRegisterWithdraw CashRegisterWithdraw[]
  cashRegisterTransaction  CashRegisterRecord[]
  assignments       CashRegisterAssignment[]
  @@index([createdAt])
  @@index([status])
}

model CashRegisterRecord {
  id              Int       @id @default(autoincrement())

  cashRegisterId  Int
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id])

  opening_at      DateTime
  closing_at      DateTime?
  starting_cash   Float
  ending_cash     Float?

  shopId          Int
  shop            Shop @relation(fields: [shopId], references: [id])

  userId          Int
  user            User @relation(fields: [userId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashRegisterId])
  @@index([shopId])
  @@index([userId])
}

model CashRegisterWithdraw {
  id              Int       @id @default(autoincrement())

  time            DateTime
  amount          Float

  cashRegisterId  Int?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  userId          Int?
  user            User? @relation(fields: [userId], references: [id])

  note            String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([cashRegisterId])
  @@index([userId])
  @@index([time])
}


model Transactions {
  id                       Int       @id @default(autoincrement())
  reference                String    @unique

  createdById              Int
  createdBy                User      @relation(fields: [createdById], references: [id])

  cashRegisterId           Int?
  cashRegister             CashRegister? @relation(fields: [cashRegisterId], references: [id])

  bankAccountId           Int?
  bankAccount             BankAccount?   @relation(fields: [bankAccountId], references: [id])

  accountId                Int
  account                  Accounts  @relation(fields: [accountId], references: [id])

  saleId                   Int?
  sale                     Sale?     @relation(fields: [saleId], references: [id])

  purchaseId               Int?
  purchase                 Purchase? @relation(fields: [purchaseId], references: [id])

  purpose                  String?
  added_to_account         Boolean?
  amount                   Float?
  payment_method           String?
  current_account_balance  Float?
  note                     String?

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([createdById])
  @@index([cashRegisterId])
  @@index([accountId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([createdAt])
}

model EntityAccount {
  id          Int       @id @default(autoincrement())
  entityType  String    // "store", "shop", "factory"
  entityId    Int       
  accountId   Int
  account     Accounts  @relation(fields: [accountId], references: [id])
  isPrimary   Boolean   @default(false)
  assignedAt  DateTime  @default(now())
  assignedById Int?
  assignedBy  User?     @relation(fields: [assignedById], references: [id])

  @@unique([entityType, entityId, accountId])
  @@index([entityType, entityId])
  @@index([accountId])
  @@index([assignedAt])
}

model Material {
  id                  Int                  @id @default(autoincrement())
  name                String
  description         String?
  brand               String?
  barcode             String?              @unique
  image               String?
  unit                String
  unit_cost           Float
  sale_price          Float?  
  current_stock       Float                @default(0)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  alert_quantity      Float                @default(0)
  ProductMaterial     ProductMaterial[]
  storeMaterials      StoreMaterial[]
  productionMaterials ProductionMaterial[]
  purchaseItems       PurchaseItem[]
  shopMaterial        ShopMaterial[]
  
  factoryMaterials    FactoryMaterial[]
  saleItem            SaleItem[]
  saleReturnItem      SaleReturnItem[]
  materialRepairItem  MaterialRepairItem[]
  ScrapMaterial       ScrapMaterial[]
  purchaseShipmentItems PurchaseShipmentItem[]
  warranties            UserWarranty[]
}

model Product {
  id                      Int                      @id @default(autoincrement())
  name                    String
  description             String?
  image                   String?
  sale_price              Float
  wholesale_price         Float
  cost                    Float
  barcode                 String?                  @unique
  defaultWarrantyDays     Int?                     @default(0)
  category                String?
  stock                   Int                      @default(0)
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  alert_quantity          Int                      @default(0) 
  materials               ProductMaterial[]
  productionProducts      ProductionProducts[]
  storeProducts           StoreProduct[]
  saleItem                SaleItem[]
  warranties              UserWarranty[]
  saleReturnItem           SaleReturnItem[]
  shopProduct             ShopProduct[]
  
  factoryProducts         FactoryProduct[]
  purchaseItem            PurchaseItem[]
  productRepairItem       ProductRepairItem[]
  scrapProduct            ScrapProduct[]
  purchaseShipmentItems   PurchaseShipmentItem[]
}

model ProductMaterial {
  product_id        Int
  material_id       Int
  material_quantity Float
  price             Float

  product  Product  @relation(fields: [product_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([product_id, material_id])
}

model Factory {
  id          Int          @id @default(autoincrement())
  name        String
  phone       String?
  manager     String?
  email       String?
  address     String?
  productions Production[] // Added for relation
  factoryProducts FactoryProduct[]
  factoryMaterials FactoryMaterial[]
}
model Production {
  id                      Int                      @id @default(autoincrement()) // Changed to Int
  reference               String                   @unique
  start_date              DateTime
  estimated_end_date      DateTime
  end_date                DateTime?
  factoryId               Int
  factory                 Factory                  @relation(fields: [factoryId], references: [id])
  status                  String                   @default("pending") // e.g., "pending", "running", "done"
  attachments             String? // Changed to String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  productionProducts      ProductionProducts[]
  productionMaterials     ProductionMaterial[]
}

model Store {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  address                 String?
  store_keeper            String?
  mobile                  String?
  storeMaterials          StoreMaterial[]
  storeProducts           StoreProduct[]
  
  //sales                   Sale[]
  //saleReturns             SaleReturn[]
}

model StoreMaterial {
  store_id    Int
  material_id Int
  stock       Float @default(0)
  avg_cost   Float?
  scrap      Float? @default(0)
  batchDetails Json?
  store    Store    @relation(fields: [store_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([store_id, material_id])
}

model StoreProduct {
  store_id   Int
  product_id Int
  stock      Float @default(0)
  avg_cost  Float?
  scrap      Float? @default(0)
  batchDetails Json?
  store   Store   @relation(fields: [store_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([store_id, product_id])
}

model ProductionProducts {
  id             Int        @id @default(autoincrement()) // Changed to Int
  productionId   Int // Changed to Int
  production     Production @relation(fields: [productionId], references: [id])
  productId      Int
  product        Product    @relation(fields: [productId], references: [id])
  code           String
  batchNumber    String?
  expiryDate     DateTime?
  manufactureDate DateTime?
  batchNotes     String?
  quantity       Float
  unit_cost      Float
  received       Float      @default(0)
  scrap          Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ProductionMaterial {
  id           Int        @id @default(autoincrement())
  productionId Int
  production   Production @relation(fields: [productionId], references: [id])
  materialId   Int
  material     Material   @relation(fields: [materialId], references: [id])
  quantity     Float
  price        Float
  scrap        Float      @default(0)
  fineMaterial Float      @default(0)

  @@unique([productionId, materialId])
}



model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  mobile    String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[] @relation("SupplierPurchases")
}

model Purchase {
  id         Int      @id @default(autoincrement())
  reference   String?       @unique
  supplierId Int
  destinationType String? // New: "store", "shop", "factory"
  destinationId   Int?    // New: ID of store/shop/factory
  supplier   Supplier @relation(fields: [supplierId], references: [id], name: "SupplierPurchases")
  createdAt  DateTime @default(now())
  grandTotal   Float
  paidAmount   Float     @default(0)
  shippingStatus String   @default("pending")
  shippingCost Float?
  discount     Float?
  tax          Float?
  purchaseItems PurchaseItem[]
  purchaseShipments PurchaseShipment[]
  transactions Transactions[]

  accountId       Int?          
  account         Accounts?     @relation(fields: [accountId], references: [id])

  @@index([destinationType])
  @@index([destinationId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  materialId Int?
  material   Material? @relation(fields: [materialId], references: [id])
  productId  Int?
  product    Product?  @relation(fields: [productId], references: [id])
  itemType   String   @default("material") // "material" or "product"
  batchNumber    String?
  expiryDate     DateTime?
  manufactureDate DateTime?
  batchNotes     String?
  quantity   Float
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  shipmentItems PurchaseShipmentItem[]

  @@unique([purchaseId, productId, materialId])
  @@index([productId])
  @@index([materialId])
}

model PurchaseShipment {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  reference  String?  @unique
  status     String   @default("pending")
  note       String?
  receivedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      PurchaseShipmentItem[]

  @@index([purchaseId])
}

model PurchaseShipmentItem {
  id              Int      @id @default(autoincrement())
  shipmentId      Int
  shipment        PurchaseShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  purchaseItemId  Int?
  purchaseItem    PurchaseItem? @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  itemType        String   @default("material")
  materialId      Int?
  material        Material? @relation(fields: [materialId], references: [id])
  productId       Int?
  product         Product?  @relation(fields: [productId], references: [id])
  quantity        Float
  received_quantity Float  @default(0)
  createdAt       DateTime @default(now())

  @@index([shipmentId])
  @@index([purchaseItemId])
  @@index([materialId])
  @@index([productId])
}

model Sale {
  id          Int          @id @default(autoincrement())
  reference   String       @unique
  //storeId     Int?
  shopId      Int?
  //store       Store?        @relation(fields: [storeId], references: [id])
  shop        Shop?        @relation(fields: [shopId], references: [id])
  bankAccountId Int?
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  bankName    String?
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  totalAmount Float
  total_cost  Float?
  discount    Float        @default(0)
  grandTotal  Float
  paidAmount  Float        @default(0)
  paymentType String       @default("cash") // e.g. cash, card, mobile
  createdAt   DateTime     @default(now())
  saleItems   SaleItem[]
  warranties  UserWarranty[]
  saleReturns SaleReturn[]
  isReturned  Boolean      @default(false)
  returnedAt  DateTime?
  transactions Transactions[]
  
  @@index([shopId])
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  saleId     Int
  sale       Sale    @relation(fields: [saleId], references: [id])
  productId  Int?
  product    Product? @relation(fields: [productId], references: [id])
  materialId Int?
  material   Material? @relation(fields: [materialId], references: [id])
  batchNumber String?
  expiryDate DateTime?
  warrantyDays Int?      @default(0)
  warrantyStartDate DateTime?
  warrantyEndDate DateTime?
  warrantySerial String?
  warrantyNotes String?
  quantity   Float
  unitPrice  Float
  avg_cost   Float?
  totalPrice Float
  userWarranties UserWarranty[]

  @@index([productId])
  @@index([materialId])
  @@index([warrantySerial])
}

model SaleReturn {
  id          Int              @id @default(autoincrement())
  saleId      Int
  sale        Sale             @relation(fields: [saleId], references: [id])
  //storeId     Int?
  shopId      Int?
  shop        Shop?            @relation(fields: [shopId], references: [id])
  //store       Store?            @relation(fields: [storeId], references: [id])
  reference   String           @unique
  totalAmount Float
  createdAt   DateTime         @default(now())
  returnItems SaleReturnItem[]
}

model SaleReturnItem {
  id           Int        @id @default(autoincrement())
  saleReturnId Int
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])
  productId    Int?
  product      Product?    @relation(fields: [productId], references: [id])
  materialId   Int?       
  material     Material?  @relation(fields: [materialId], references: [id])
  quantity     Float
  unitPrice    Float
  totalPrice   Float
}

model Shop {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  address     String?
  shop_keeper String?
  mobile      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relations
  shopProducts  ShopProduct[]
  shopMaterials ShopMaterial[]
  sales         Sale[]
  saleReturns   SaleReturn[]
  
  cashRegisterRecord  CashRegisterRecord[]
}

model ShopProduct {
  shop_id    Int
  product_id Int
  stock      Float @default(0)
  avg_cost  Float?
  scrap      Float? @default(0)
  batchDetails Json?
  shop    Shop    @relation(fields: [shop_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([shop_id, product_id])
}

model ShopMaterial {
  shop_id     Int
  material_id Int
  stock       Float @default(0)
  avg_cost   Float?
  scrap      Float? @default(0)
  batchDetails Json?
  shop     Shop     @relation(fields: [shop_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([shop_id, material_id])
}




model Transfer {
  id            Int            @id @default(autoincrement())
  reference     String         @unique
  from          String
  fromId        Int
  to            String
  toId          Int
  shipping_cost Float
  status        String         @default("processing")
  isRecived     Boolean?       @default(false)
  note          String?
  document      String?
  createdAt     DateTime  @default(now())
  transferItems TransferItem[]
}

model TransferItem {
  id         Int      @id @default(autoincrement())
  transferId Int
  productId  Int?
  materialId Int?
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item       String
  itemId     Int
  batchNumber String?
  expiryDate DateTime?
  quantity   Float
  receivedQuantity   Float?
  avg_cost   Float?
}

model FactoryProduct {
  factoryId Int
  productId Int
  stock     Float @default(0)
  avg_cost Float?  
  scrap      Float? @default(0)
  batchDetails Json?
  factory   Factory @relation(fields: [factoryId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@id([factoryId, productId])
}

model FactoryMaterial {
  factoryId  Int
  materialId Int
  stock      Float @default(0)
  avg_cost  Float? 
  scrap      Float? @default(0)
  batchDetails Json?
  factory  Factory  @relation(fields: [factoryId], references: [id])
  material Material @relation(fields: [materialId], references: [id])

  @@id([factoryId, materialId])
}

model Notification {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  link        String?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  forRole     String

  @@index([isRead])
  @@index([createdAt])
}

model ProductRepair {
  id              Int       @id @default(autoincrement())
  destination     String
  shippingCost    Float
  document        String?
  note            String?
  status          String @default("pending") // pending, in_progress, completed, failed
  from            String   //store, shop or factory
  fromId          Int
  accountId       Int?
  createdAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  productRepairItem  ProductRepairItem[]

  @@index([createdAt])
}

model ProductRepairItem {
  id          Int       @id @default(autoincrement())
  repairId    Int 
  productId   Int
  quantity    Float
  success     Float
  fail        Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  repair      ProductRepair  @relation(fields: [repairId], references: [id])
  product     Product        @relation(fields: [productId], references: [id])

  @@index([createdAt])
}

model ScrapProductRecord {
  id          Int       @id @default(autoincrement())
  reason      String 
  note        String
  totalLoss   Float
  fromType    String?   // Add this - "store", "shop", or "factory"
  fromBranchId Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scrapProduct ScrapProduct[]

  @@index([createdAt])
}

model ScrapProduct {
  id          Int       @id @default(autoincrement())
  scrapProductRecordId  Int
  productId   Int      
  quantity    Float
  lossPerUnit Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  record      ScrapProductRecord @relation(fields: [scrapProductRecordId], references: [id])
  product     Product            @relation(fields: [productId], references: [id])

  @@index([createdAt])
}


model MaterialRepair {
  id              Int       @id @default(autoincrement())
  destination     String
  shippingCost    Float
  document        String?
  note            String?
  status          String @default("pending") // pending, in_progress, completed, failed
  from            String   //store, shop or factory
  fromId          Int
  accountId       Int?
  createdAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  materialRepairItem  MaterialRepairItem[]

  @@index([createdAt])
}

model MaterialRepairItem {
  id          Int       @id @default(autoincrement())
  repairId    Int 
  materialId   Int
  quantity    Float
  success     Float
  fail        Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  repair      MaterialRepair  @relation(fields: [repairId], references: [id])
  material     Material        @relation(fields: [materialId], references: [id])

  @@index([createdAt])
}

model ScrapMaterialRecord {
  id          Int       @id @default(autoincrement())
  reason      String 
  note        String
  totalLoss   Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scrapMaterial ScrapMaterial[]

  @@index([createdAt])
}

model ScrapMaterial {
  id          Int       @id @default(autoincrement())
  scrapMaterialRecordId  Int
  materialId   Int      
  quantity    Float
  lossPerUnit Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  record       ScrapMaterialRecord @relation(fields: [scrapMaterialRecordId], references: [id])
  material     Material            @relation(fields: [materialId], references: [id])

  @@index([createdAt])
}


model Customer {
  id              Int       @id @default(autoincrement())
  name            String
  mobile          String    @unique
  email           String?   @unique
  address         String?
  total_purchase  Float     @default(0)
  total_due       Float     @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sales           Sale[]
  warranties      UserWarranty[]

  @@index([name])
  @@index([mobile])
}

model UserWarranty {
  id              Int       @id @default(autoincrement())
  warrantyCode    String    @unique
  status          String    @default("active")
  serialNumber    String?
  notes           String?
  startDate       DateTime
  endDate         DateTime
  claimCount      Int       @default(0)
  claimedAt       DateTime?
  voidedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  saleId          Int
  sale            Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleItemId      Int
  saleItem        SaleItem  @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  productId       Int?
  product         Product?  @relation(fields: [productId], references: [id])
  materialId      Int?
  material        Material? @relation(fields: [materialId], references: [id])
  customerId      Int?
  customer        Customer? @relation(fields: [customerId], references: [id])
  claims          WarrantyClaim[]

  @@index([saleId])
  @@index([saleItemId])
  @@index([productId])
  @@index([materialId])
  @@index([customerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model WarrantyClaim {
  id               Int          @id @default(autoincrement())
  warrantyId       Int
  warranty         UserWarranty @relation(fields: [warrantyId], references: [id], onDelete: Cascade)
  receivingDate    DateTime
  providingDate    DateTime?
  issueDescription String?
  resolution       String?
  status           String       @default("received")
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([warrantyId])
  @@index([receivingDate])
  @@index([providingDate])
  @@index([status])
}


