// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String?
  password    String
  role        Role     @default(USER)
  permissions Json?    @default("{}")
  profile     Profile? @relation(fields: [profileId], references: [id])
  profileId   Int?     @unique
}

model Profile {
  id   Int     @id @default(autoincrement())
  bio  String?
  user User?
}

enum Role {
  USER
  ADMIN
}

model Material {
  id                  Int                  @id @default(autoincrement())
  name                String
  description         String?
  brand               String?
  barcode             String?              @unique
  image               String?
  unit                String
  unit_cost           Float
  current_stock       Float                @default(0)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  ProductMaterial     ProductMaterial[]
  storeMaterials      StoreMaterial[]
  productionMaterials ProductionMaterial[]
  purchaseItems       PurchaseItem[]
  shopMaterial        ShopMaterial[]
}

model Product {
  id                      Int                      @id @default(autoincrement())
  name                    String
  description             String?
  image                   String?
  sale_price              Float
  wholesale_price         Float
  cost                    Float
  barcode                 String?                  @unique
  category                String?
  stock                   Int                      @default(0)
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  materials               ProductMaterial[]
  productionProducts      ProductionProducts[]
  storeProducts           StoreProduct[]
  factoryToStoreTransfers FactoryToStoreTransfer[]
  saleItem                SaleItem[]
  saleReturnItem           SaleReturnItem[]
  shopProduct             ShopProduct[]
}

model ProductMaterial {
  product_id        Int
  material_id       Int
  material_quantity Float
  price             Float

  product  Product  @relation(fields: [product_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([product_id, material_id])
}

model Factory {
  id          Int          @id @default(autoincrement())
  name        String
  phone       String?
  manager     String?
  email       String?
  address     String?
  productions Production[] // Added for relation
}

model Production {
  id                      Int                      @id @default(autoincrement()) // Changed to Int
  reference               String                   @unique
  start_date              DateTime
  estimated_end_date      DateTime
  end_date                DateTime?
  factoryId               Int
  factory                 Factory                  @relation(fields: [factoryId], references: [id])
  status                  String                   @default("pending") // e.g., "pending", "running", "done"
  attachments             String? // Changed to String?
  shipping_cost           Float?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  productionProducts      ProductionProducts[]
  productionMaterials     ProductionMaterial[]
  factoryToStoreTransfers FactoryToStoreTransfer[]
}

model Store {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  address                 String?
  store_keeper            String?
  mobile                  String?
  storeMaterials          StoreMaterial[]
  storeProducts           StoreProduct[]
  productionMaterials     ProductionMaterial[]
  factoryToStoreTransfers FactoryToStoreTransfer[]
  purchases               Purchase[]
  //sales                   Sale[]
  //saleReturns             SaleReturn[]
}

model StoreMaterial {
  store_id    Int
  material_id Int
  stock       Float @default(0)

  store    Store    @relation(fields: [store_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([store_id, material_id])
}

model StoreProduct {
  store_id   Int
  product_id Int
  stock      Float @default(0)

  store   Store   @relation(fields: [store_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([store_id, product_id])
}

model ProductionProducts {
  id             Int        @id @default(autoincrement()) // Changed to Int
  productionId   Int // Changed to Int
  production     Production @relation(fields: [productionId], references: [id])
  productId      Int
  product        Product    @relation(fields: [productId], references: [id])
  code           String
  quantity       Float
  unit_cost      Float
  moved_to_store Float
  received       Float      @default(0)
  scrap          Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model ProductionMaterial {
  id           Int        @id @default(autoincrement())
  productionId Int
  production   Production @relation(fields: [productionId], references: [id])
  materialId   Int
  material     Material   @relation(fields: [materialId], references: [id])
  storeId      Int
  store        Store      @relation(fields: [storeId], references: [id])
  quantity     Float
  price        Float
  scrap        Float      @default(0)

  @@unique([productionId, materialId, storeId])
}

model FactoryToStoreTransfer {
  id           Int        @id @default(autoincrement())
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  productionId Int
  production   Production @relation(fields: [productionId], references: [id])
  storeId      Int
  store        Store      @relation(fields: [storeId], references: [id])
  quantity     Float
  createdAt    DateTime   @default(now())
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  mobile    String?
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[] @relation("SupplierPurchases")
}

model Purchase {
  id         Int      @id @default(autoincrement())
  reference   String?       @unique
  supplierId Int
  storeId    Int?
  supplier   Supplier @relation(fields: [supplierId], references: [id], name: "SupplierPurchases")
  createdAt  DateTime @default(now())
  store      Store?   @relation(fields: [storeId], references: [id])
  grandTotal  Float
  purchaseItems PurchaseItem[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  materialId Int
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Float
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  @@unique([purchaseId, materialId])
}

model Sale {
  id          Int          @id @default(autoincrement())
  reference   String       @unique
  //storeId     Int?
  shopId      Int?
  //store       Store?        @relation(fields: [storeId], references: [id])
  shop        Shop?        @relation(fields: [shopId], references: [id])
  customer    String?
  totalAmount Float
  discount    Float        @default(0)
  grandTotal  Float
  paymentType String       @default("cash") // e.g. cash, card, mobile
  createdAt   DateTime     @default(now())
  saleItems   SaleItem[]
  saleReturns SaleReturn[]

  
  @@index([shopId])
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  saleId     Int
  sale       Sale    @relation(fields: [saleId], references: [id])
  productId  Int
  product    Product @relation(fields: [productId], references: [id])
  quantity   Float
  unitPrice  Float
  totalPrice Float
}

model SaleReturn {
  id          Int              @id @default(autoincrement())
  saleId      Int
  sale        Sale             @relation(fields: [saleId], references: [id])
  //storeId     Int?
  shopId      Int?
  shop        Shop?            @relation(fields: [shopId], references: [id])
  //store       Store?            @relation(fields: [storeId], references: [id])
  reference   String           @unique
  totalAmount Float
  createdAt   DateTime         @default(now())
  returnItems SaleReturnItem[]
}

model SaleReturnItem {
  id           Int        @id @default(autoincrement())
  saleReturnId Int
  saleReturn   SaleReturn @relation(fields: [saleReturnId], references: [id])
  productId    Int
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Float
  unitPrice    Float
  totalPrice   Float
}

model Shop {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  address     String?
  shop_keeper String?
  mobile      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relations
  shopProducts  ShopProduct[]
  shopMaterials ShopMaterial[]
  sales         Sale[]
  saleReturns   SaleReturn[]
}

model ShopProduct {
  shop_id    Int
  product_id Int
  stock      Float @default(0)

  shop    Shop    @relation(fields: [shop_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@id([shop_id, product_id])
}

model ShopMaterial {
  shop_id     Int
  material_id Int
  stock       Float @default(0)

  shop     Shop     @relation(fields: [shop_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([shop_id, material_id])
}