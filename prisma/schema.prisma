// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  name        String?
  password    String
  role        Role     @default(USER)
  permissions Json?    @default("{}")
  profile     Profile? @relation(fields: [profileId], references: [id])
  profileId   Int?     @unique
}

model Profile {
  id   Int    @id @default(autoincrement())
  bio  String?
  user User?
}

enum Role {
  USER
  ADMIN
}

model Material {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  brand         String?
  barcode       String?  @unique
  image         String?
  unit          String
  unit_cost     Float
  current_stock Float    @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  ProductMaterial ProductMaterial[]
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  image           String?
  sale_price      Float
  wholesale_price Float
  cost            Float
  barcode         String?   @unique
  category        String?
  stock           Int       @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  materials       ProductMaterial[]
  productionProducts ProductionProducts[] // Added for relation
}

model ProductMaterial {
  product_id        Int
  material_id       Int
  material_quantity Float
  price             Float

  product  Product  @relation(fields: [product_id], references: [id])
  material Material @relation(fields: [material_id], references: [id])

  @@id([product_id, material_id])
}

model Factory {
  id      Int     @id @default(autoincrement())
  name    String
  phone   String?
  manager String?
  email   String?
  address String?
  productions Production[] // Added for relation
}

model Production {
  id                 Int                 @id @default(autoincrement()) // Changed to Int
  reference          String              @unique
  start_date         DateTime
  estimated_end_date DateTime
  factoryId          Int
  factory            Factory             @relation(fields: [factoryId], references: [id])
  status             String              @default("pending") // e.g., "pending", "running", "done"
  attachments        String?             // Changed to String?
  shipping_cost      Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  productionProducts ProductionProducts[]
}

model ProductionProducts {
  id           Int       @id @default(autoincrement()) // Changed to Int
  productionId Int       // Changed to Int
  production   Production @relation(fields: [productionId], references: [id])
  productId    Int
  product      Product   @relation(fields: [productId], references: [id])
  code         String
  quantity     Float
  unit_cost    Float
  moved_to_store Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}